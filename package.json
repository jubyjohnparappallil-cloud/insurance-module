{
  "name": "shanthi-wellness-emr",
  "version": "1.0.0",
  "description": "Shanthi Wellness Ayurvedic Medical Centre - Clinic EMR",
  "main": "main.js",
  "author": "Shanthi Wellness",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.shanthiwellness.emr",
    "productName": "Shanthi Wellness EMR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "insurance-only.html",
      "icd-codes.js",
      "clinic-data.json",
      "logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "clinic-data.json",
        "to": "clinic-data.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shanthi Wellness EMR"
    },
    "portable": {
      "artifactName": "ShanthiWellness-EMR-Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "nodemailer": "^6.9.7",
    "pcsclite": "^1.0.1",
    "ws": "^8.21.0"
  }
}
