{
  "name": "shanthi-wellness-emr",
  "version": "1.0.0",
  "description": "Shanthi Wellness Ayurvedic Medical Centre - Clinic EMR",
  "main": "server.js",
  "author": "Shanthi Wellness",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "insurance": "node server.js",
    "usermgmt": "node server.js --usermgmt",
    "server:wellness": "node server.js --wellness",
    "both": "start cmd /k node server.js & start cmd /k node server.js --usermgmt",
    "import:medical": "node import-medical.js",
    "import:wellness": "node import-wellness.js",
    "import:medical:preview": "node import-medical.js --dry-run",
    "import:wellness:preview": "node import-wellness.js --dry-run",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.shanthiwellness.emr",
    "productName": "Shanthi Wellness EMR",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "insurance-only.html",
      "icd-codes.js",
      "clinic-data.json",
      "logo.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "clinic-data.json",
        "to": "clinic-data.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shanthi Wellness EMR"
    },
    "portable": {
      "artifactName": "ShanthiWellness-EMR-Portable.exe"
    }
  },
  "devDependencies": {
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "nodemailer": "^6.9.7",
    "ws": "^8.21.0"
  }
}
